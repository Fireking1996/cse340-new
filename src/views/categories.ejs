<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
   <p>Here are the available categories:</p>

    <ul>

        <% categories.forEach(category => { %>

            <li>

                <a href="/category/<%= category.category_id %>">

                    <%= category.name %>

                </a>

            </li>

        <% }); %>

    

    </ul>

    <% categories.forEach(category => { %>

    <li>
        <%= category.name %>

        <a href="/category/<%= category.category_id %>">View</a>
        <a href="/edit-category/<%= category.category_id %>">Edit</a>
    </li>

<% }) %>

<p><a href="/new-category">Add a New Category</a></p>


</main>

<%- include('partials/footer') %>