<%- include('partials/header') %>

<h1><%= title %></h1>

<h2><%= project.title %></h2>

<form action="/project/<%= project.project_id %>/assign-categories" method="POST">

    <% categories.forEach(category => { %>

    <label>
        <input
            type="checkbox"
            name="categories"
            value="<%= category.category_id %>"
            <%= assignedCategories.some(ac => Number(ac.category_id) === Number(category.category_id)) ? 'checked' : '' %>
        >
        <%= category.name %>
    </label>
    <br>

<% }) %>

    <button type="submit">Save Categories</button>
</form>

<%- include('partials/footer') %>